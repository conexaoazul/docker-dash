{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-container resource usage from Docker Dash (v7.6.0). Top 10 by CPU + memory + a full table with both. Built on docker_dash_container_cpu / docker_dash_container_memory_bytes metrics exposed at /api/metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
      "description": "Top 10 containers by CPU usage right now. Click a series in the legend to highlight.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "CPU %",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "decimals": 1,
          "unit": "percent"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
          "expr": "topk(10, docker_dash_container_cpu)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 — CPU",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
      "description": "Top 10 containers by memory usage. Bytes — Grafana auto-formats as MB/GB.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "Memory",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto"
          },
          "decimals": 1,
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
          "expr": "topk(10, docker_dash_container_memory_bytes)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Top 10 — Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
      "description": "All containers, current snapshot. Sortable. CPU is %, memory is bytes (Grafana auto-formats).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
              { "id": "max", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              { "id": "decimals", "value": 1 }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [{ "displayName": "CPU %", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
          "expr": "docker_dash_container_cpu",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "docker-dash-prom" },
          "expr": "docker_dash_container_memory_bytes",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "All containers — sortable",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "name", "mode": "inner" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time 1": true, "Time 2": true, "__name__ 1": true, "__name__ 2": true, "instance 1": true, "instance 2": true, "job 1": true, "job 2": true },
            "renameByName": { "name": "Container", "Value #A": "CPU %", "Value #B": "Memory" }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docker-dash", "containers"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Docker Dash — Top Containers",
  "uid": "docker-dash-top-containers",
  "version": 1,
  "weekStart": ""
}
